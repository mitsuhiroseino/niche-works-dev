{
  "name": "@niche-works/dev",
  "version": "0.2.0",
  "keywords": [
    "utils"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mitsuhiroseino/niche-works-dev.git"
  },
  "license": "MIT",
  "author": "Mitsuhiro Seino",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*/index.ts",
    "./*/constants": "./src/*/constants.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "dev": "tsup --watch",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "indexes": "tsx scripts/indexes.ts",
    "lint": "tsup --dry-run",
    "tidy": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\" --config ./prettier.tidy.config.js"
  },
  "dependencies": {
    "fs-extra": "^11.3.4",
    "remeda": "^2.33.6"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "glob": "^13.0.6",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "rimraf": "^6.1.3",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "type-fest": "^5.5.0",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.32.1"
}
