{
  "name": "@niche-works/dev",
  "version": "0.5.3",
  "private": true,
  "keywords": [
    "utils"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mitsuhiroseino/niche-works-dev.git"
  },
  "license": "MIT",
  "author": "Mitsuhiro Seino",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*/index.ts",
    "./*/constants": "./src/*/constants.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit",
    "dev": "tsdown --watch",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "indexes": "tsx scripts/indexes.ts",
    "lint": "tsdown --dry-run",
    "tidy": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\" --config ./prettier.tidy.config.js"
  },
  "dependencies": {
    "fs-extra": "^11.3.4",
    "remeda": "^2.33.6",
    "sass": "^1.99.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@niche-works/rollup-plugin-dist-package": "^0.2.2",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.5",
    "fast-glob": "^3.3.3",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "rollup-plugin-copy": "^3.5.0",
    "tsdown": "^0.22.0",
    "tsx": "^4.21.0",
    "type-fest": "^5.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.32.1"
}
